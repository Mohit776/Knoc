{
  "expo": {
    "name": "KNOC",
    "slug": "KNOC",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/main_logo/new_logo.png",
    "scheme": "knoc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/main_logo/adaptive_screen.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.knoc.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/main_logo/icon_app.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/main_logo/splase_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/main_logo/notification_logo.png",
          "color": "#431BB8"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8fc41524-ec08-4732-a91f-43aa808af971"
      }
    }
  }
}