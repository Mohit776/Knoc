{
  "expo": {
    "name": "KNOC",
    "slug": "KNOC",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/new_knoc/Bsee_icon_app_11zon.png",
    "scheme": "knoc",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.knoc.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/new_knoc/Adaptive_forground_11zon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.knoc.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/new_knoc/Bsee_icon_app_11zon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/new_knoc/Splace_Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#341dab",
          "dark": {
            "backgroundColor": "#341dab"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/new_knoc/Notification.png",
          "color": "#341dab"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a54e5f2-0c2c-4ff8-baed-3d961d34b2ea"
      }
    }
  }
}