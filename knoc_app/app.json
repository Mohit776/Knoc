{
  "expo": {
    "name": "KNOC",
    "slug": "knoc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/logo2.png",
    "scheme": "knocapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.knoc.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/logo2.png",
        "backgroundImage": "./assets/logo/logo2.png",
        "monochromeImage": "./assets/logo/logo2.png"
      },
      "package": "com.knoc.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/logo2.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/Group 1171275857.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo/logo2.png",
          "color": "#431BB8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}